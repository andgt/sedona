{
  "name": "project",
  "private": true,
  "description": "Личный проект от HTML Academy",
  "devDependencies": {
    "@htmlacademy/editorconfig-cli": "^2.0.10",
    "autoprefixer": "^10.4.0",
    "browser-sync": "^3.0.4",
    "gulp": "4.0.2",
    "gulp-clean": "^0.4.0",
    "gulp-htmlmin": "^5.0.1",
    "gulp-imagemin": "^7.1.0",
    "gulp-plumber": "1.2.1",
    "gulp-postcss": "9.0.1",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-svgstore": "^7.0.1",
    "gulp-terser": "^2.1.0",
    "gulp-webp": "^4.0.1",
    "postcss": "8.3.11",
    "postcss-csso": "^5.0.1",
    "sass": "^1.97.3",
    "stylelint": "^13.13.1",
    "stylelint-config-htmlacademy": "0.1.11"
  },
  "overrides": {
    "es5-ext": "0.10.53"
  },
  "scripts": {
    "editorconfig": "editorconfig-cli",
    "stylelint": "stylelint \"source/sass/**/*.scss\"",
    "lint": "npm run editorconfig && npm run stylelint",
    "build": "gulp build",
    "start": "gulp"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not ie <= 11",
    "not op_mini all",
    "not < 0.25%"
  ],
  "editorconfig-cli": [
    "*.json",
    "*.js",
    "source/*.html",
    "source/js/**/*.js",
    "source/img/**/*.svg",
    "source/sass/**/*.scss"
  ],
  "engines": {
    "node": "^16"
  }
}
